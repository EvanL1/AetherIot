{
  "name": "aether-docs",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "sync": "node scripts/sync-content.mjs",
    "check:language": "node scripts/check-language.mjs",
    "check:audience": "node scripts/check-audience.mjs",
    "build": "npm run sync && npm run check:language && npm run check:audience && astro build && node scripts/build-docs.mjs",
    "check": "npm run sync && npm run check:language && npm run check:audience && astro check",
    "dev": "npm run sync && npm run check:language && npm run check:audience && astro dev",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:worker": "vitest run --config vitest.workers.config.js"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/starlight": "^0.41.3",
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@vitest/coverage-v8": "^4.1.10",
    "astro": "^7.0.7",
    "fast-glob": "^3.3.3",
    "github-slugger": "^2.0.0",
    "sharp": "^0.34.5",
    "starlight-links-validator": "^0.25.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
