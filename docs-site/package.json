{
  "name": "docs-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "sync": "node scripts/sync-content.mjs",
    "dev": "npm run sync && astro dev",
    "check": "npm run sync && astro check",
    "build": "npm run sync && astro build && node scripts/emit-markdown-pages.mjs",
    "preview": "wrangler dev",
    "test": "vitest run",
    "test:worker": "vitest run --config vitest.workers.config.js"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.41.3",
    "astro": "^7.0.2",
    "sharp": "^0.34.5",
    "starlight-links-validator": "^0.25.2",
    "starlight-llms-txt": "^0.11.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "fast-glob": "^3.3.3",
    "github-slugger": "^2.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
