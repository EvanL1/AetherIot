# Copy to /etc/aether/load-forecasting-processor.env with mode 0600.
# Replace every placeholder; never commit the commissioned secret or digest.
AETHER_LOAD_FORECASTING_REQUIRE_AUTH=true
AETHER_LOAD_FORECASTING_BEARER_TOKEN=replace-with-secret
AETHER_LOAD_FORECASTING_MAX_CONCURRENCY=1
AETHER_LOAD_FORECASTING_ARTIFACT_BUNDLES='[{"kind":"model","family":"site-load","version":"v3","expected_digest":"sha256:<64-lowercase-hex>","files":{"model":"/opt/load-forecasting/artifacts/v3/model.onnx","scaler":"/opt/load-forecasting/artifacts/v3/scaler.json","config":"/opt/load-forecasting/artifacts/v3/features.json"}}]'
