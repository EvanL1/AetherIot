# Copy to /etc/aether/pv-forecasting-processor.env with mode 0600.
# Replace every placeholder; never commit the commissioned secret or digest.
AETHER_PV_FORECASTING_REQUIRE_AUTH=true
AETHER_PV_FORECASTING_BEARER_TOKEN=replace-with-secret
AETHER_PV_FORECASTING_MAX_CONCURRENCY=1
AETHER_PV_FORECASTING_ARTIFACT_BUNDLES='[{"kind":"model","family":"site-pv","version":"v3","expected_digest":"sha256:<64-lowercase-hex>","files":{"model":"/opt/pv-forecasting/artifacts/v3/model.onnx","scaler":"/opt/pv-forecasting/artifacts/v3/scaler.json","config":"/opt/pv-forecasting/artifacts/v3/features.json"}}]'
