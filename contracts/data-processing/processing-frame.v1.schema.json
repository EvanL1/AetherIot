{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "processing-frame.v1.schema.json",
  "title": "Aether Processing Frame v1",
  "description": "The complete, bounded data frame that Aether supplies to a data processor.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "as_of",
    "cadence_seconds",
    "history",
    "quality",
    "provenance"
  ],
  "properties": {
    "schema": {
      "const": "aether.processing-frame.v1"
    },
    "as_of": {
      "$ref": "#/$defs/utcTimestamp"
    },
    "cadence_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 86400
    },
    "history": {
      "$ref": "#/$defs/segment"
    },
    "future_covariates": {
      "$ref": "#/$defs/segment"
    },
    "static_features": {
      "$ref": "#/$defs/staticFeatureMap"
    },
    "quality": {
      "$ref": "#/$defs/frameQuality"
    },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "maxItems": 512,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/provenanceEntry"
      }
    }
  },
  "$defs": {
    "utcTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:(?:[0-5][0-9]|60)(?:\\.[0-9]{1,3})?Z$"
    },
    "featureName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\\u0000-\\u001F\\u007F]+$"
    },
    "unit": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[^\\u0000-\\u001F\\u007F]+$"
    },
    "sampleQuality": {
      "enum": [
        "good",
        "uncertain",
        "substituted",
        "missing"
      ]
    },
    "finiteNumber": {
      "type": "number",
      "minimum": -1.7976931348623157e308,
      "maximum": 1.7976931348623157e308
    },
    "qualityArray": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20000,
      "items": {
        "$ref": "#/$defs/sampleQuality"
      }
    },
    "numberSeries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value_type",
        "unit",
        "values",
        "quality"
      ],
      "properties": {
        "value_type": {
          "const": "number"
        },
        "unit": {
          "$ref": "#/$defs/unit"
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20000,
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/finiteNumber"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "quality": {
          "$ref": "#/$defs/qualityArray"
        }
      }
    },
    "stringSeries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value_type",
        "values",
        "quality"
      ],
      "properties": {
        "value_type": {
          "const": "string"
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20000,
          "items": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "quality": {
          "$ref": "#/$defs/qualityArray"
        }
      }
    },
    "booleanSeries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value_type",
        "values",
        "quality"
      ],
      "properties": {
        "value_type": {
          "const": "boolean"
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20000,
          "items": {
            "type": [
              "boolean",
              "null"
            ]
          }
        },
        "quality": {
          "$ref": "#/$defs/qualityArray"
        }
      }
    },
    "featureSeries": {
      "oneOf": [
        {
          "$ref": "#/$defs/numberSeries"
        },
        {
          "$ref": "#/$defs/stringSeries"
        },
        {
          "$ref": "#/$defs/booleanSeries"
        }
      ]
    },
    "featureMap": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 128,
      "$comment": "Feature names are the deliberate extension point. Every dynamic property value remains governed by featureSeries.",
      "propertyNames": {
        "$ref": "#/$defs/featureName"
      },
      "additionalProperties": {
        "$ref": "#/$defs/featureSeries"
      }
    },
    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamps",
        "features"
      ],
      "properties": {
        "timestamps": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20000,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/utcTimestamp"
          }
        },
        "features": {
          "$ref": "#/$defs/featureMap"
        }
      },
      "$comment": "Draft 2020-12 cannot express that every values and quality array has exactly the timestamps length, nor strict timestamp order/cadence. The Rust domain validator enforces those dependent invariants."
    },
    "numberStaticFeature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value_type",
        "unit",
        "value",
        "quality"
      ],
      "properties": {
        "value_type": {
          "const": "number"
        },
        "unit": {
          "$ref": "#/$defs/unit"
        },
        "value": {
          "oneOf": [
            {
              "$ref": "#/$defs/finiteNumber"
            },
            {
              "type": "null"
            }
          ]
        },
        "quality": {
          "$ref": "#/$defs/sampleQuality"
        }
      }
    },
    "stringStaticFeature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value_type",
        "value",
        "quality"
      ],
      "properties": {
        "value_type": {
          "const": "string"
        },
        "value": {
          "type": [
            "string",
            "null"
          ]
        },
        "quality": {
          "$ref": "#/$defs/sampleQuality"
        }
      }
    },
    "booleanStaticFeature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value_type",
        "value",
        "quality"
      ],
      "properties": {
        "value_type": {
          "const": "boolean"
        },
        "value": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "quality": {
          "$ref": "#/$defs/sampleQuality"
        }
      }
    },
    "staticFeature": {
      "oneOf": [
        {
          "$ref": "#/$defs/numberStaticFeature"
        },
        {
          "$ref": "#/$defs/stringStaticFeature"
        },
        {
          "$ref": "#/$defs/booleanStaticFeature"
        }
      ]
    },
    "staticFeatureMap": {
      "type": "object",
      "maxProperties": 128,
      "$comment": "Static feature names are the deliberate extension point. Every dynamic property value remains governed by staticFeature.",
      "propertyNames": {
        "$ref": "#/$defs/featureName"
      },
      "additionalProperties": {
        "$ref": "#/$defs/staticFeature"
      }
    },
    "frameQuality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_watermark",
        "missing_ratio",
        "max_gap_seconds",
        "live_tail_included",
        "substituted_samples"
      ],
      "properties": {
        "input_watermark": {
          "$ref": "#/$defs/utcTimestamp"
        },
        "missing_ratio": {
          "$ref": "#/$defs/finiteNumber",
          "minimum": 0,
          "maximum": 1
        },
        "max_gap_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "live_tail_included": {
          "type": "boolean"
        },
        "substituted_samples": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "provenanceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "segment",
        "feature",
        "source_kind",
        "watermark"
      ],
      "properties": {
        "segment": {
          "enum": [
            "history",
            "future_covariates",
            "static_features"
          ]
        },
        "feature": {
          "$ref": "#/$defs/featureName"
        },
        "source_kind": {
          "enum": [
            "history",
            "live",
            "history_and_live",
            "covariate",
            "calendar",
            "constant"
          ]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,2047}$"
        },
        "watermark": {
          "$ref": "#/$defs/utcTimestamp"
        },
        "issued_at": {
          "$ref": "#/$defs/utcTimestamp"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "segment": {
                "const": "history"
              }
            },
            "required": [
              "segment"
            ]
          },
          "then": {
            "properties": {
              "source_kind": {
                "enum": [
                  "history",
                  "live",
                  "history_and_live",
                  "calendar"
                ]
              }
            },
            "not": {
              "required": [
                "issued_at"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "segment": {
                "const": "future_covariates"
              }
            },
            "required": [
              "segment"
            ]
          },
          "then": {
            "properties": {
              "source_kind": {
                "enum": [
                  "covariate",
                  "calendar",
                  "constant"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "segment": {
                "const": "static_features"
              }
            },
            "required": [
              "segment"
            ]
          },
          "then": {
            "properties": {
              "source_kind": {
                "const": "constant"
              }
            },
            "not": {
              "required": [
                "issued_at"
              ]
            }
          }
        },
        {
          "if": {
            "required": [
              "issued_at"
            ]
          },
          "then": {
            "properties": {
              "segment": {
                "const": "future_covariates"
              },
              "source_kind": {
                "const": "covariate"
              }
            }
          }
        }
      ],
      "$comment": "issued_at is the optional issue cut of a versioned external forecast. The Rust domain enforces issued_at <= watermark <= frame.as_of and verifies that segment/feature identifies an existing frame feature. source_ref is a redaction-safe semantic identifier, never a URL, path, SQL fragment, or physical point coordinate."
    }
  }
}
