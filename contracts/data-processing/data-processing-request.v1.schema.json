{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "data-processing-request.v1.schema.json",
  "title": "Aether DataProcessingRequest v1",
  "description": "Processor-facing request assembled by Aether from a commissioned task and binding. It carries the complete frame and never grants the processor a callback into Aether data sources.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "request_id",
    "submitted_at",
    "deadline",
    "task",
    "binding",
    "processor_contract",
    "frame",
    "options",
    "input_digest"
  ],
  "properties": {
    "schema": {
      "const": "aether.data-processing.request.v1"
    },
    "request_id": {
      "$ref": "#/$defs/uuid"
    },
    "submitted_at": {
      "$ref": "#/$defs/utcTimestamp"
    },
    "deadline": {
      "$ref": "#/$defs/utcTimestamp"
    },
    "task": {
      "$ref": "#/$defs/taskIdentity"
    },
    "binding": {
      "$ref": "#/$defs/bindingIdentity"
    },
    "processor_contract": {
      "$ref": "#/$defs/identifier"
    },
    "artifact": {
      "$ref": "#/$defs/artifactSelector"
    },
    "frame": {
      "$ref": "processing-frame.v1.schema.json"
    },
    "options": {
      "$ref": "#/$defs/forecastOptions"
    },
    "input_digest": {
      "$ref": "#/$defs/sha256Digest"
    }
  },
  "$comment": "The schema validates shape. The Rust domain also proves deadline > submitted_at, task/options agreement, frame.as_of and watermark bounds, canonical digest equality, timestamp order/cadence, and array-length dependencies.",
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4294967295
    },
    "finiteNumber": {
      "type": "number",
      "minimum": -1.7976931348623157e308,
      "maximum": 1.7976931348623157e308
    },
    "probability": {
      "allOf": [
        { "$ref": "#/$defs/finiteNumber" },
        {
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 1
        }
      ]
    },
    "uuid": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[1-8][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$"
    },
    "utcTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:(?:[0-5][0-9]|60)(?:\\.[0-9]{1,3})?Z$"
    },
    "sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "taskIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "revision", "kind"],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "revision": {
          "$ref": "#/$defs/revision"
        },
        "kind": {
          "const": "forecast"
        }
      }
    },
    "bindingIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "revision"],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "revision": {
          "$ref": "#/$defs/revision"
        }
      }
    },
    "artifactSelector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "family"],
      "properties": {
        "kind": {
          "$ref": "#/$defs/identifier"
        },
        "family": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/identifier"
        },
        "artifact_digest": {
          "$ref": "#/$defs/sha256Digest"
        }
      }
    },
    "forecastOptions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "horizon_steps"],
      "properties": {
        "kind": {
          "const": "forecast"
        },
        "horizon_steps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4096
        },
        "quantiles": {
          "type": "array",
          "minItems": 1,
          "maxItems": 19,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/probability"
          },
          "$comment": "Ascending order is a semantic domain invariant that Draft 2020-12 cannot express for arbitrary arrays."
        }
      }
    }
  }
}
