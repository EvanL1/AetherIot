{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "processing-result.v1.schema.json",
  "title": "Aether ProcessingResult v1",
  "description": "Untrusted processor result. Aether validates correlation, provenance, output semantics, horizon, and expiry before creating DerivedData.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "request_id",
    "task",
    "binding",
    "input_digest",
    "status",
    "issued_at",
    "input_watermark",
    "processor",
    "warnings"
  ],
  "properties": {
    "schema": {
      "const": "aether.data-processing.result.v1"
    },
    "request_id": {
      "$ref": "#/$defs/uuid"
    },
    "task": {
      "$ref": "#/$defs/taskIdentity"
    },
    "binding": {
      "$ref": "#/$defs/bindingIdentity"
    },
    "input_digest": {
      "$ref": "#/$defs/sha256Digest"
    },
    "status": {
      "enum": ["produced", "fallback", "unavailable"]
    },
    "issued_at": {
      "$ref": "#/$defs/utcTimestamp"
    },
    "expires_at": {
      "$ref": "#/$defs/utcTimestamp"
    },
    "input_watermark": {
      "$ref": "#/$defs/utcTimestamp"
    },
    "processor": {
      "$ref": "#/$defs/processorIdentity"
    },
    "artifact": {
      "$ref": "#/$defs/artifactProvenance"
    },
    "output": {
      "$ref": "forecast-output.v1.schema.json"
    },
    "fallback": {
      "$ref": "#/$defs/fallbackInfo"
    },
    "unavailable": {
      "$ref": "#/$defs/unavailableInfo"
    },
    "warnings": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/stableCode"
      }
    }
  },
  "oneOf": [
    {
      "title": "Produced result",
      "required": ["expires_at", "output"],
      "properties": {
        "status": { "const": "produced" },
        "fallback": false,
        "unavailable": false
      }
    },
    {
      "title": "Approved fallback result",
      "required": ["expires_at", "output", "fallback"],
      "properties": {
        "status": { "const": "fallback" },
        "unavailable": false
      }
    },
    {
      "title": "Unavailable result",
      "required": ["unavailable"],
      "properties": {
        "status": { "const": "unavailable" },
        "expires_at": false,
        "output": false,
        "fallback": false
      }
    }
  ],
  "$comment": "The schema makes status envelopes disjoint. The Rust domain additionally compares issued/expires/watermark times, request correlation, exact horizon/cadence, task fields, requested quantiles, quantile ordering, and task expiry policy.",
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4294967295
    },
    "uuid": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[1-8][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$"
    },
    "utcTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:(?:[0-5][0-9]|60)(?:\\.[0-9]{1,3})?Z$"
    },
    "sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "stableCode": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "taskIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "revision", "kind"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "revision": { "$ref": "#/$defs/revision" },
        "kind": { "const": "forecast" }
      }
    },
    "bindingIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "revision"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "revision": { "$ref": "#/$defs/revision" }
      }
    },
    "processorIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "contract"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "version": { "$ref": "#/$defs/identifier" },
        "contract": { "$ref": "#/$defs/identifier" }
      }
    },
    "artifactProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "family", "version", "artifact_digest"],
      "properties": {
        "kind": { "$ref": "#/$defs/identifier" },
        "family": { "$ref": "#/$defs/identifier" },
        "version": { "$ref": "#/$defs/identifier" },
        "artifact_digest": { "$ref": "#/$defs/sha256Digest" }
      }
    },
    "fallbackInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "strategy_version",
        "reason_code",
        "source_feature",
        "based_on_data_through"
      ],
      "properties": {
        "strategy": { "$ref": "#/$defs/identifier" },
        "strategy_version": { "$ref": "#/$defs/identifier" },
        "reason_code": { "$ref": "#/$defs/stableCode" },
        "source_feature": { "$ref": "#/$defs/identifier" },
        "based_on_data_through": { "$ref": "#/$defs/utcTimestamp" }
      }
    },
    "unavailableInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason_code", "retryable"],
      "properties": {
        "reason_code": { "$ref": "#/$defs/stableCode" },
        "retryable": { "type": "boolean" },
        "retry_after_seconds": {
          "$ref": "#/$defs/positiveInteger"
        }
      },
      "oneOf": [
        {
          "properties": {
            "retryable": { "const": true }
          }
        },
        {
          "properties": {
            "retryable": { "const": false },
            "retry_after_seconds": false
          }
        }
      ],
      "$comment": "A retry delay is optional when retryable is true and forbidden when retryable is false, matching UnavailableInfo."
    }
  }
}
