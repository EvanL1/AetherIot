{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "derived-data.v1.schema.json",
  "title": "Aether DerivedData v1",
  "description": "Aether-stamped data created only after an untrusted ProcessingResult passes domain and application validation. Unavailable or rejected results never become DerivedData.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "result_id",
    "request_id",
    "task",
    "binding",
    "accepted_at",
    "expires_at",
    "input_digest",
    "processing_status",
    "processor",
    "warnings",
    "quality",
    "data"
  ],
  "properties": {
    "schema": {
      "const": "aether.derived-data.v1"
    },
    "result_id": {
      "$ref": "#/$defs/uuid"
    },
    "request_id": {
      "$ref": "#/$defs/uuid"
    },
    "task": {
      "$ref": "processing-result.v1.schema.json#/$defs/taskIdentity"
    },
    "binding": {
      "$ref": "processing-result.v1.schema.json#/$defs/bindingIdentity"
    },
    "accepted_at": {
      "$ref": "#/$defs/utcTimestamp"
    },
    "expires_at": {
      "$ref": "#/$defs/utcTimestamp"
    },
    "input_digest": {
      "$ref": "#/$defs/sha256Digest"
    },
    "processing_status": {
      "enum": ["produced", "fallback"]
    },
    "processor": {
      "$ref": "#/$defs/acceptedProcessor"
    },
    "artifact": {
      "$ref": "processing-result.v1.schema.json#/$defs/artifactProvenance"
    },
    "fallback": {
      "$ref": "processing-result.v1.schema.json#/$defs/fallbackInfo"
    },
    "warnings": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/stableCode"
      }
    },
    "quality": {
      "oneOf": [
        { "$ref": "#/$defs/producedQuality" },
        { "$ref": "#/$defs/fallbackQuality" }
      ]
    },
    "data": {
      "$ref": "forecast-output.v1.schema.json"
    }
  },
  "oneOf": [
    {
      "properties": {
        "processing_status": { "const": "produced" },
        "fallback": false,
        "quality": { "$ref": "#/$defs/producedQuality" }
      }
    },
    {
      "required": ["fallback"],
      "properties": {
        "processing_status": { "const": "fallback" },
        "quality": { "$ref": "#/$defs/fallbackQuality" }
      }
    }
  ],
  "$comment": "The Rust domain remains authoritative for result correlation, accepted_at/expires_at ordering, task output agreement, freshness, and all forecast semantic invariants.",
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "uuid": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[1-8][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$"
    },
    "utcTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:(?:[0-5][0-9]|60)(?:\\.[0-9]{1,3})?Z$"
    },
    "sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "stableCode": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "finiteRatio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "acceptedProcessor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "contract"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "version": { "$ref": "#/$defs/identifier" },
        "contract": { "$ref": "#/$defs/identifier" }
      }
    },
    "producedQuality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_watermark",
        "missing_ratio",
        "max_gap_seconds",
        "live_tail_included",
        "substituted_samples",
        "fallback_used"
      ],
      "properties": {
        "input_watermark": { "$ref": "#/$defs/utcTimestamp" },
        "missing_ratio": { "$ref": "#/$defs/finiteRatio" },
        "max_gap_seconds": { "type": "integer", "minimum": 0 },
        "live_tail_included": { "type": "boolean" },
        "substituted_samples": { "type": "integer", "minimum": 0 },
        "fallback_used": { "const": false }
      }
    },
    "fallbackQuality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_watermark",
        "missing_ratio",
        "max_gap_seconds",
        "live_tail_included",
        "substituted_samples",
        "fallback_used"
      ],
      "properties": {
        "input_watermark": { "$ref": "#/$defs/utcTimestamp" },
        "missing_ratio": { "$ref": "#/$defs/finiteRatio" },
        "max_gap_seconds": { "type": "integer", "minimum": 0 },
        "live_tail_included": { "type": "boolean" },
        "substituted_samples": { "type": "integer", "minimum": 0 },
        "fallback_used": { "const": true }
      }
    }
  }
}
