{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "forecast-output.v1.schema.json",
  "title": "Aether Forecast Output v1",
  "description": "A typed, time-indexed forecast output produced by a data processor.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "kind",
    "target",
    "unit",
    "sign_convention",
    "cadence_seconds",
    "timestamp_semantics",
    "points"
  ],
  "properties": {
    "schema": {
      "const": "aether.data-processing.output.forecast.v1"
    },
    "kind": {
      "const": "forecast"
    },
    "target": {
      "$ref": "#/$defs/featureName"
    },
    "unit": {
      "$ref": "#/$defs/unit"
    },
    "sign_convention": {
      "$ref": "#/$defs/identifier"
    },
    "cadence_seconds": {
      "$ref": "#/$defs/positiveInteger"
    },
    "timestamp_semantics": {
      "const": "interval_end",
      "$comment": "The version 1 Rust codec and forecast domain use interval-end points. A different timestamp interpretation requires a future contract version."
    },
    "points": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/forecastPoint"
      },
      "$comment": "Point count, strict timestamp order, cadence, and exact horizon agreement are cross-contract semantic validations."
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "featureName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\\u0000-\\u001F\\u007F]+$"
    },
    "unit": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[^\\u0000-\\u001F\\u007F]+$"
    },
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "finiteNumber": {
      "type": "number",
      "minimum": -1.7976931348623157e308,
      "maximum": 1.7976931348623157e308
    },
    "probability": {
      "allOf": [
        {
          "$ref": "#/$defs/finiteNumber"
        },
        {
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 1
        }
      ]
    },
    "utcTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:(?:[0-5][0-9]|60)(?:\\.[0-9]{1,3})?Z$"
    },
    "quantile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "probability",
        "value"
      ],
      "properties": {
        "probability": {
          "$ref": "#/$defs/probability"
        },
        "value": {
          "$ref": "#/$defs/finiteNumber"
        }
      }
    },
    "forecastPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamp",
        "value"
      ],
      "properties": {
        "timestamp": {
          "$ref": "#/$defs/utcTimestamp"
        },
        "value": {
          "$ref": "#/$defs/finiteNumber"
        },
        "quantiles": {
          "type": "array",
          "minItems": 1,
          "maxItems": 19,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/quantile"
          },
          "$comment": "Unique probabilities, increasing probability order, and nondecreasing values remain semantic validations."
        }
      }
    }
  }
}
