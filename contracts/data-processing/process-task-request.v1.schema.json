{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "process-task-request.v1.schema.json",
  "title": "Aether Process Task Request v1",
  "description": "The application-facing request for executing a commissioned data-processing task.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "expected_task_revision",
    "binding_id",
    "expected_binding_revision",
    "as_of",
    "options"
  ],
  "properties": {
    "task_id": {
      "$ref": "#/$defs/identifier"
    },
    "expected_task_revision": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4294967295
    },
    "binding_id": {
      "$ref": "#/$defs/identifier"
    },
    "expected_binding_revision": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4294967295
    },
    "as_of": {
      "$ref": "#/$defs/utcTimestamp"
    },
    "options": {
      "$ref": "#/$defs/forecastOptions"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "finiteNumber": {
      "type": "number",
      "minimum": -1.7976931348623157e308,
      "maximum": 1.7976931348623157e308
    },
    "probability": {
      "allOf": [
        {
          "$ref": "#/$defs/finiteNumber"
        },
        {
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 1
        }
      ]
    },
    "utcTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:(?:[0-5][0-9]|60)(?:\\.[0-9]{1,3})?Z$"
    },
    "forecastOptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "horizon_steps"
      ],
      "properties": {
        "kind": {
          "const": "forecast"
        },
        "horizon_steps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4096
        },
        "quantiles": {
          "type": "array",
          "minItems": 1,
          "maxItems": 19,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/probability"
          },
          "$comment": "Ascending quantile order is a semantic validation that Draft 2020-12 cannot express for an arbitrary array."
        }
      }
    }
  }
}
