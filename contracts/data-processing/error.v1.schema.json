{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "error.v1.schema.json",
  "title": "Aether Data Processing Error v1",
  "description": "Typed non-2xx error envelope for transport, contract, capacity, authorization, and unexpected processor failures.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "code", "category", "message", "retryable"],
  "properties": {
    "schema": {
      "const": "aether.data-processing.error.v1"
    },
    "request_id": {
      "$ref": "#/$defs/uuid"
    },
    "code": {
      "$ref": "#/$defs/stableCode"
    },
    "category": {
      "enum": [
        "invalid_request",
        "authorization",
        "not_found",
        "conflict",
        "resource_limit",
        "invalid_data",
        "capacity",
        "internal",
        "unavailable",
        "timeout"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^[^\\u0000-\\u0008\\u000B\\u000C\\u000E-\\u001F\\u007F]+$"
    },
    "retryable": {
      "type": "boolean"
    },
    "details": {
      "$ref": "#/$defs/errorDetails"
    }
  },
  "$comment": "request_id is optional because syntax, media-type, and authentication failures may occur before correlation is available. Code/category/retry consistency and secret-safe message redaction remain adapter and Rust port validations.",
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[1-8][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$"
    },
    "stableCode": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "errorDetails": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 32,
      "properties": {
        "path": {
          "type": "string",
          "maxLength": 2048,
          "pattern": "^/"
        },
        "rule": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "retry_after_seconds": {
          "type": "integer",
          "minimum": 1
        }
      },
      "$comment": "Diagnostic fields are deliberately closed. New detail fields require a contract revision; credentials, model paths, queries, stack traces, and source payloads are forbidden."
    }
  }
}
