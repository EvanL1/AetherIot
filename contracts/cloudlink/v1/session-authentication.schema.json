{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "session-authentication.schema.json",
  "title": "Planned CloudLink production session authentication profile",
  "description": "Non-authoritative product history. Public alpha.3 freezes the challenge and signature proposal shapes, while production key provisioning, verification, rotation, revocation, and verifier ownership remain unresolved. Trusted Broker attestation is never accepted from MQTT payload bytes.",
  "oneOf": [
    { "$ref": "#/$defs/challengeRequest" },
    { "$ref": "#/$defs/challenge" },
    { "$ref": "#/$defs/sessionProof" }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-8][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "positiveUint64": {
      "type": "string",
      "pattern": "^[1-9][0-9]{0,19}$"
    },
    "unixTimeMs": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]{0,14})$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "nonce": {
      "type": "string",
      "minLength": 22,
      "maxLength": 86,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "credentialBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["credential_id", "generation"],
      "properties": {
        "credential_id": { "$ref": "#/$defs/identifier" },
        "generation": { "$ref": "#/$defs/positiveUint64" }
      }
    },
    "resumeCursor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stream_id", "stream_epoch", "acknowledged_position"],
      "properties": {
        "stream_id": { "$ref": "#/$defs/identifier" },
        "stream_epoch": { "$ref": "#/$defs/positiveUint64" },
        "acknowledged_position": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]{0,19})$"
        }
      }
    },
    "challengeRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "protocol",
        "message_kind",
        "gateway_id",
        "credential_binding",
        "offered_protocol_versions",
        "client_nonce",
        "resume"
      ],
      "properties": {
        "schema": { "const": "aether.cloudlink.session-challenge-request.v1" },
        "protocol": { "const": "aether.cloudlink" },
        "message_kind": { "const": "session-challenge-request" },
        "gateway_id": { "$ref": "#/$defs/uuid" },
        "credential_binding": { "$ref": "#/$defs/credentialBinding" },
        "offered_protocol_versions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": { "const": "1.0" }
        },
        "client_nonce": { "$ref": "#/$defs/nonce" },
        "resume": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/resumeCursor" }
        }
      }
    },
    "challenge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "protocol",
        "message_kind",
        "gateway_id",
        "client_nonce",
        "challenge_id",
        "server_nonce",
        "hello_digest",
        "broker_binding",
        "issued_at_ms",
        "expires_at_ms",
        "cloud_key_id",
        "cloud_signature"
      ],
      "properties": {
        "schema": { "const": "aether.cloudlink.session-challenge.v1" },
        "protocol": { "const": "aether.cloudlink" },
        "message_kind": { "const": "session-challenge" },
        "gateway_id": { "$ref": "#/$defs/uuid" },
        "client_nonce": { "$ref": "#/$defs/nonce" },
        "challenge_id": { "$ref": "#/$defs/uuid" },
        "server_nonce": { "$ref": "#/$defs/nonce" },
        "hello_digest": { "$ref": "#/$defs/sha256" },
        "broker_binding": { "$ref": "#/$defs/identifier" },
        "issued_at_ms": { "$ref": "#/$defs/unixTimeMs" },
        "expires_at_ms": { "$ref": "#/$defs/unixTimeMs" },
        "cloud_key_id": { "$ref": "#/$defs/identifier" },
        "cloud_signature": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{86}$"
        }
      }
    },
    "gatewaySignature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "algorithm", "key_id", "signature"],
      "properties": {
        "method": { "const": "gateway-signature" },
        "algorithm": { "const": "Ed25519" },
        "key_id": { "$ref": "#/$defs/identifier" },
        "signature": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{86}$"
        }
      }
    },
    "trustedBrokerAttestation": {
      "type": "object",
      "description": "Adapter-created context from verified Broker metadata; never a wire payload field.",
      "additionalProperties": false,
      "required": [
        "method",
        "broker_connection_id",
        "attestation_id",
        "attested_principal",
        "gateway_id",
        "credential_id",
        "credential_generation",
        "hello_digest",
        "issued_at_ms",
        "expires_at_ms"
      ],
      "properties": {
        "method": { "const": "trusted-broker-attestation" },
        "broker_connection_id": { "$ref": "#/$defs/identifier" },
        "attestation_id": { "$ref": "#/$defs/identifier" },
        "attested_principal": { "$ref": "#/$defs/identifier" },
        "gateway_id": { "$ref": "#/$defs/uuid" },
        "credential_id": { "$ref": "#/$defs/identifier" },
        "credential_generation": { "$ref": "#/$defs/positiveUint64" },
        "hello_digest": { "$ref": "#/$defs/sha256" },
        "issued_at_ms": { "$ref": "#/$defs/unixTimeMs" },
        "expires_at_ms": { "$ref": "#/$defs/unixTimeMs" }
      }
    },
    "authenticationMethod": {
      "oneOf": [
        { "$ref": "#/$defs/gatewaySignature" },
        { "$ref": "#/$defs/trustedBrokerAttestation" }
      ]
    },
    "sessionProof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "protocol",
        "message_kind",
        "gateway_id",
        "credential_binding",
        "client_nonce",
        "challenge_id",
        "server_nonce",
        "hello_digest",
        "broker_binding",
        "challenge_issued_at_ms",
        "challenge_expires_at_ms",
        "authentication"
      ],
      "properties": {
        "schema": { "const": "aether.cloudlink.session-proof.v1" },
        "protocol": { "const": "aether.cloudlink" },
        "message_kind": { "const": "session-proof" },
        "gateway_id": { "$ref": "#/$defs/uuid" },
        "credential_binding": { "$ref": "#/$defs/credentialBinding" },
        "client_nonce": { "$ref": "#/$defs/nonce" },
        "challenge_id": { "$ref": "#/$defs/uuid" },
        "server_nonce": { "$ref": "#/$defs/nonce" },
        "hello_digest": { "$ref": "#/$defs/sha256" },
        "broker_binding": { "$ref": "#/$defs/identifier" },
        "challenge_issued_at_ms": { "$ref": "#/$defs/unixTimeMs" },
        "challenge_expires_at_ms": { "$ref": "#/$defs/unixTimeMs" },
        "authentication": { "$ref": "#/$defs/gatewaySignature" }
      }
    }
  }
}
