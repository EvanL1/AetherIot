{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aether.dev/schemas/pack-rule.v1.json",
  "title": "Aether Pack Rule v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "name", "description", "enabled", "commissioned", "priority", "flow_json"],
  "properties": {
    "schema": { "const": "aether.pack.rule.v1" },
    "id": { "$ref": "#/$defs/identifier" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "enabled": { "const": false },
    "commissioned": { "const": false },
    "priority": { "type": "integer", "minimum": 0 },
    "flow_json": {
      "type": "object",
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": { "type": "array" },
        "edges": { "type": "array" }
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    }
  }
}
