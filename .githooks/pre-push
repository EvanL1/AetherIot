#!/usr/bin/env bash
set -e

echo "🚀 Running pre-push checks..."

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# 运行标准 clippy 检查（不包括 unwrap/expect 警告）
echo "🔍 Running standard clippy checks..."
if ! cargo clippy --all-targets --all-features -- -D warnings; then
    echo -e "${RED}❌ Clippy checks failed!${NC}"
    echo "Fix the issues before pushing"
    exit 1
fi

# 可选：显示严格检查的结果（仅供参考，不阻止推送）
echo "📊 Running optional strict checks (informational only)..."
cargo clippy --all-targets --all-features -- \
    -D warnings \
    -W clippy::unwrap_used \
    -W clippy::expect_used \
    -W clippy::panic \
    -W clippy::unimplemented \
    -W clippy::todo 2>&1 | grep -E "warning:|error:" | head -10 || true
if [ ${PIPESTATUS[0]} -ne 0 ]; then
    echo -e "${YELLOW}ℹ️  Some strict checks would fail (see above). Consider addressing these in future commits.${NC}"
fi

# 检查依赖安全性
if command -v cargo-audit &> /dev/null; then
    echo "🔐 Checking for security vulnerabilities..."
    if ! cargo audit --ignore RUSTSEC-2023-0071; then
        echo -e "${YELLOW}⚠️  Security vulnerabilities found in dependencies${NC}"
    fi
else
    echo -e "${YELLOW}⚠️  cargo-audit not installed, skipping security check${NC}"
    echo "Install with: cargo install cargo-audit"
fi

# 检查未使用的依赖
if command -v cargo-udeps &> /dev/null; then
    echo "📦 Checking for unused dependencies..."
    if ! cargo +nightly udeps --all-targets; then
        echo -e "${YELLOW}⚠️  Unused dependencies found${NC}"
    fi
else
    echo -e "${YELLOW}⚠️  cargo-udeps not installed, skipping dependency check${NC}"
    echo "Install with: cargo install cargo-udeps"
fi

# 测试将在 CI 中运行，这里跳过以加快推送速度
# echo "🧪 Running all tests..."
# if ! cargo test --workspace; then
#     echo -e "${RED}❌ Tests failed!${NC}"
#     exit 1
# fi

# 检查文档
echo "📚 Checking documentation..."
if ! cargo doc --no-deps --document-private-items --all-features; then
    echo -e "${YELLOW}⚠️  Documentation issues found${NC}"
fi

echo -e "${GREEN}✅ All pre-push checks passed!${NC}"
